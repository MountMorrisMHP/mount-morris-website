# Dependencies — these get reinstalled with "npm install", no need to track them.
node_modules/

# Generated static site — produced by "node build.js" and by the Pages action.
# It is rebuilt on every deploy, so it should not be committed.
dist/

# The client's data folder is intentionally tracked. Keep it and everything
# inside it under version control so listings live in the repo.
!mount-morris-management/

